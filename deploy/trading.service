[Unit]
Description=Trading Record API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/tradingRecords/backend
Environment=UPLOAD_DIR=/opt/tradingRecordsData/uploads
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
