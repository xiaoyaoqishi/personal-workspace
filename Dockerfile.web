FROM node:22-alpine AS builder
WORKDIR /app

COPY frontend-trading/package*.json /app/frontend-trading/
COPY frontend-notes/package*.json /app/frontend-notes/
COPY frontend-monitor/package*.json /app/frontend-monitor/
COPY frontend-ledger/package*.json /app/frontend-ledger/

RUN cd /app/frontend-trading && npm ci
RUN cd /app/frontend-notes && npm ci
RUN cd /app/frontend-monitor && npm ci
RUN cd /app/frontend-ledger && npm ci

COPY frontend-trading /app/frontend-trading
COPY frontend-notes /app/frontend-notes
COPY frontend-monitor /app/frontend-monitor
COPY frontend-ledger /app/frontend-ledger
COPY portal /app/portal

RUN cd /app/frontend-trading && npm run build
RUN cd /app/frontend-notes && npm run build
RUN cd /app/frontend-monitor && npm run build
RUN cd /app/frontend-ledger && npm run build

FROM nginx:1.27-alpine
COPY deploy/docker/nginx.docker.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/portal /usr/share/nginx/html/portal
COPY --from=builder /app/frontend-trading/dist /usr/share/nginx/html/frontend-trading/dist
COPY --from=builder /app/frontend-notes/dist /usr/share/nginx/html/frontend-notes/dist
COPY --from=builder /app/frontend-monitor/dist /usr/share/nginx/html/frontend-monitor/dist
COPY --from=builder /app/frontend-ledger/dist /usr/share/nginx/html/frontend-ledger/dist
